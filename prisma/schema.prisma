generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["db_growstore_schemas"]
}

model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.VarChar(60)
  email     String   @unique @db.VarChar(60)
  password  String   @db.VarChar(80)
  birthDate DateTime @map("birth_date") @db.Date

  createdAt DateTime @default(now()) @map("created_at")
  updateAt  DateTime @updatedAt @map("update_at")

  @@map("user")
  @@schema("db_growstore_schemas")
}

model Product {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productName String  @map("product_name") @db.VarChar(100)
  description String  @db.VarChar(300)
  brand       String  @db.VarChar(20)
  collection  String? @db.VarChar(60)
  material    String  @db.VarChar(60)
  gender      String  @db.VarChar(40)
  status      String  @db.VarChar(40)

  createdAt DateTime @default(now()) @map("created_at")
  updateAt  DateTime @updatedAt @map("update_at")

  categoryId String   @db.Uuid()
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("product")
  @@schema("db_growstore_schemas")
}

model ProductVariant {
  id    String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sku   String  @unique @db.VarChar(60)
  color String  @db.VarChar(20)
  size  String  @db.Char(1)
  stock Int     @default(0)
  price Decimal

  createdAt DateTime @default(now()) @map("created_at")
  updateAtd DateTime @updatedAt @map("update_at")

  @@map("product_variant")
  @@schema("db_growstore_schemas")
}

model Category {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name String @db.VarChar(80)

  createdAt DateTime  @default(now()) @map("created_at")
  updateAt  DateTime  @updatedAt @map("update_at")

  products  Product[]

  @@map("category")
  @@schema("db_growstore_schemas")
}

model ProductImage {
  id           String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  url          String
  altText      String @map("alt_text") @db.VarChar(60)
  displayOrder Int    @map("display_order")


  @@map("product_image")
  @@schema("db_growstore_schemas")
}
